{
  "name": "quiz-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"const fs=require('fs'); ['.next/dev/lock'].forEach((p)=>{try{if(fs.existsSync(p)) fs.rmSync(p,{force:true});}catch{}})\"",
    "dev": "concurrently \"npm run next\" \"npm run python\"",
    "next": "next dev",
    "python": "python -m uvicorn python.api:app --reload --host 127.0.0.1 --port 8000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
